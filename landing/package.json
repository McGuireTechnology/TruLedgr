{
  "name": "truledgr-www",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TruLedgr Landing Page - Vue.js frontend",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only",
    "build:landing": "npm run build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "deploy": "wrangler pages deploy dist --project-name=truledgr-www",
    "deploy:staging": "wrangler pages deploy dist --project-name=truledgr-www-staging",
    "deploy:preview": "wrangler pages deploy dist --project-name=truledgr-www-preview"
  },
  "dependencies": {
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/node": "^22.16.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "prettier": "3.6.2",
    "terser": "^5.43.1",
    "typescript": "~5.8.0",
    "vite": "^6.0.1",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4",
    "wrangler": "^3.57.2"
  }
}