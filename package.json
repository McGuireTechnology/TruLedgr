{
  "name": "truledgr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "run-p build:dash build:landing",
    "dev:dash": "npm --prefix dash run dev",
    "dev:landing": "npm --prefix landing run dev",
    "build:dash": "npm --prefix dash run build",
    "build:landing": "npm --prefix landing run build",
    "build:landing-ci": "npm --prefix landing install --include=dev && npm --prefix landing run build",
    "preview:dash": "npm --prefix dash run preview",
    "preview:landing": "npm --prefix landing run preview",
    "lint:dash": "npm --prefix dash run lint",
    "lint:landing": "npm --prefix landing run lint",
    "format:dash": "npm --prefix dash run format",
    "format:landing": "npm --prefix landing run format",
    "type-check:dash": "npm --prefix dash run type-check",
    "type-check:landing": "npm --prefix landing run type-check",
    "docs:install": "pip install -e \".[docs]\"",
    "docs:serve": "mkdocs serve --dev-addr localhost:8001",
    "docs:build": "mkdocs build --clean",
    "docs:deploy": "echo 'Documentation deployment is handled by GitHub Actions. Push to main branch to deploy.'",
    "migrate": "python scripts/migrate.py",
    "migrate:check": "python scripts/migrate.py check",
    "migrate:create": "python scripts/migrate.py create",
    "migrate:upgrade": "python scripts/migrate.py upgrade",
    "migrate:current": "python scripts/migrate.py current",
    "migrate:history": "python scripts/migrate.py history",
    "migrate:setup": "python scripts/migrate.py setup",
    "install:all": "npm install && npm --prefix dash install && npm --prefix landing install"
  },
  "dependencies": {
  },
  "devDependencies": {
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.4"
  }
}
